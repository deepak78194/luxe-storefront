# ── Luxe Storefront — local development secrets ─────────────────────────────
# 1. Copy this file:   cp .env.local.example .env.local
# 2. Fill in real values below
# 3. Run:              npm run generate-env
# 4. .env.local is gitignored — NEVER commit it
# ─────────────────────────────────────────────────────────────────────────────

# Sanity project settings — find at https://sanity.io/manage → your project
SANITY_PROJECT_ID=YOUR_PROJECT_ID
SANITY_DATASET=pdc1c

# Read-only Viewer token (used by the public storefront in the browser)
# Create at: sanity.io/manage → API → Tokens → Add Token → role: Viewer
SANITY_READ_TOKEN=

# Editor token (used by the admin panel — write access)
# Create at: sanity.io/manage → API → Tokens → Add Token → role: Editor
# ⚠️  This ends up in the browser bundle (see README for server-proxy option)
SANITY_WRITE_TOKEN=

# Store settings
WHATSAPP_PHONE=919876543210
STORE_NAME=Luxe Storefront
STORE_TAGLINE=Curated Fashion & Accessories

# Admin panel password — change before going live
ADMIN_PASSWORD=admin@luxe2026
