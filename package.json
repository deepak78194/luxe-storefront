{
  "name": "luxe-storefront",
  "version": "1.0.0",
  "description": "Production-grade luxury fashion ecommerce storefront",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "build": "ng build",
    "build:prod": "ng build --configuration production",
    "postbuild:prod": "node scripts/copy-404.mjs",
    "build:ssr": "ng build --configuration production && ng run luxe-storefront:server:production",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "lint": "ng lint",
    "sanity": "cd sanity-studio && sanity dev",
    "sanity:deploy": "cd sanity-studio && sanity deploy",
    "generate-env": "node scripts/generate-env.mjs",
    "prebuild": "node scripts/generate-env.mjs",
    "prebuild:prod": "node scripts/generate-env.mjs",
    "seed": "node scripts/seed.mjs",
    "seed:images": "node scripts/seed-images.mjs"
  },
  "private": true,
  "dependencies": {
    "@angular/animations": "^21.0.0",
    "@angular/common": "^21.0.0",
    "@angular/compiler": "^21.0.0",
    "@angular/core": "^21.0.0",
    "@angular/forms": "^21.0.0",
    "@angular/platform-browser": "^21.0.0",
    "@angular/platform-browser-dynamic": "^21.0.0",
    "@angular/platform-server": "^21.0.0",
    "@angular/router": "^21.0.0",
    "@angular/ssr": "^21.0.0",
    "@sanity/client": "^6.22.0",
    "@sanity/image-url": "^1.1.0",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0",
    "zone.js": "~0.16.0"
  },
  "devDependencies": {
    "@angular-devkit/build-angular": "^21.0.0",
    "@angular/cli": "^21.0.0",
    "@angular/compiler-cli": "^21.0.0",
    "@tailwindcss/postcss": "^4.2.4",
    "@tailwindcss/vite": "^4.0.0",
    "@types/jasmine": "~5.1.0",
    "@types/node": "^20.0.0",
    "jasmine-core": "~5.4.0",
    "karma": "~6.4.0",
    "karma-chrome-launcher": "~3.2.0",
    "karma-coverage": "~2.2.0",
    "karma-jasmine": "~5.1.0",
    "karma-jasmine-html-reporter": "~2.1.0",
    "tailwindcss": "^4.0.0",
    "typescript": "~5.9.0"
  }
}
